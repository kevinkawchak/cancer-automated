% ============================================================
% usctitle.sty
% Style file for:
%   VVUQ-04 full-bill: the FINISHED amendment to the Federal Food, Drug, and
%   Cosmetic Act (21 U.S.C. 301 et seq.), built on the Title 21 device
%   provisions current through Public Law 119-93.
%
% This style descends from the VVUQ-04 draft-bill style (v2.2.0). It keeps the
% United States Code look and feel for the reproduced existing-law text in the
% comparative print (black Times-like serif, bold section catchlines,
% hanging-indent statutory hierarchy, centered cross-headings, small-caps note
% headings, parenthetical source credits) and the apparatus of a congressional
% amendment (the bill caption, the "A BILL" head, the enacting clause, run-in
% bill-section catchlines, and the comparative-print strike and insert markers).
% Because this is the finished bill rather than a scaffold, the set-off DRAFTING
% INSTRUCTIONS block of the draft-bill style is intentionally removed.
%
% Senior-author formatting required by the full-bill task is centralized here:
%   - body text is set RaggedRight (ragged2e) so interword spacing is even and
%     no big gaps, rivers, or right-margin overflow appear;
%   - widow, orphan, and broken-line penalties are maximal so no single line is
%     stranded at the top or bottom of a page;
%   - the running header is abbreviated (page, a short act title, and the bill
%     number) so no two header fields overlap;
%   - long reference URLs break on any character so no link runs off the page;
%   - a left-aligned, ragged-right fixed-width column type (ragcol and L) and a
%     flexible ragged-right column (Y) are provided so every table is set to the
%     body measure with no large interword gaps and no overflow;
%   - single hyphens only (no en or em dashes) appear in this file, and the
%     section symbol is used for every codified reference.
% ============================================================
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{usctitle}[2026/06/01 v2.3.0 Food, Drug, and Cosmetic Act amendment style (full bill)]

% - Times-like serif body to match the printed United States Code. -
% newtx is standard on Overleaf and TeX Live full. If a minimal installation
% lacks it, substitute \usepackage{mathptmx} for an equivalent Times body.
\RequirePackage{newtxtext}
\RequirePackage{newtxmath}

% - Page geometry: letter paper, statute-style measure. -
\RequirePackage[letterpaper,top=1.0in,bottom=1.0in,left=1.1in,right=1.1in,%
  headheight=15pt,headsep=18pt,footskip=24pt]{geometry}

% - Black body text, faithful to the United States Code (no accent color). -
\RequirePackage{xcolor}
\RequirePackage[T1]{fontenc}
\RequirePackage[utf8]{inputenc}
\RequirePackage{textcomp}
\RequirePackage{microtype}
\RequirePackage{array}
\RequirePackage{longtable}
\RequirePackage{tabularx}
\RequirePackage{xltabular}
\RequirePackage{ragged2e}
\RequirePackage{needspace}
\RequirePackage{enumitem}

% - Hyperref for PDF bookmarks; links kept black to match the print. -
\RequirePackage[hidelinks,pdfusetitle]{hyperref}
\RequirePackage{url}

% - Even spacing with no right-margin overflow and no big interword gaps. -
% RaggedRight from ragged2e gives a soft right margin with even interword
% spacing while still allowing hyphenation, so lines are neither stretched nor
% overfull. The emergencystretch is a backstop for any justified remnant. The
% small RaggedRightRightskip stretch keeps lines full enough that no large white
% band opens between words.
\tolerance=2000
\emergencystretch=3em
\hbadness=4000
\hyphenpenalty=70
\exhyphenpenalty=70
\RaggedRight
\setlength{\RaggedRightParindent}{0pt}
\setlength{\RaggedRightRightskip}{0pt plus 2em}

% - No stranded lines: maximal widow, orphan, and broken-line penalties so a
%   single line is never carried alone to the next page and no one- or two-word
%   last line is left behind. -
\widowpenalty=10000
\clubpenalty=10000
\displaywidowpenalty=10000
\brokenpenalty=10000
\interlinepenalty=0
\predisplaypenalty=10000
\postdisplaypenalty=10000

% - Break long URLs on any character so no reference link runs off the right
%   margin in the bibliography. -
\def\UrlBreaks{\do\/\do-\do.\do=\do_\do?\do\&\do\%\do\#\do\:\do\a\do\b\do\c%
\do\d\do\e\do\f\do\g\do\h\do\i\do\j\do\k\do\l\do\m\do\n\do\o\do\p\do\q\do\r%
\do\s\do\t\do\u\do\v\do\w\do\x\do\y\do\z\do\A\do\B\do\C\do\D\do\E\do\F\do\G%
\do\H\do\I\do\J\do\K\do\L\do\M\do\N\do\O\do\P\do\Q\do\R\do\S\do\T\do\U\do\V%
\do\W\do\X\do\Y\do\Z\do\0\do\1\do\2\do\3\do\4\do\5\do\6\do\7\do\8\do\9}
\Urlmuskip=0mu plus 3mu\relax

% - Paragraph defaults: small inter-clause gap, no first-line indent. -
\setlength{\parindent}{0pt}
\setlength{\parskip}{3.2pt plus 1pt minus 0.5pt}

% - Running header: page on the left, an abbreviated act title in the center,
%   and the bill number on the right. The fields are short and fixed so no two
%   of them overlap (the draft style placed the full section heading on the
%   right, which collided with the centered title). -
\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\footrulewidth}{0pt}
\fancyhead[L]{\footnotesize\thepage}
\fancyhead[C]{\footnotesize\scshape Verification Before Generation Act of 2026}
\fancyhead[R]{\footnotesize H.\,R. 9510}
\fancypagestyle{plain}{%
  \fancyhf{}%
  \renewcommand{\headrulewidth}{0pt}%
  \fancyfoot[C]{\footnotesize\thepage}}

% - Indentation unit for the statutory hierarchy. -
\newlength{\uscunit}\setlength{\uscunit}{1.7em}

% - Left-aligned, ragged-right fixed-width table columns. -
% Use L{<width>} or \ragcol{<width>} so every cell is set
% >{\raggedright\arraybackslash}p{<width>}; the Y column is the flexible
% ragged-right column for xltabular and tabularx. Tables are set to \textwidth
% so they match the body measure exactly while cells stay left aligned with no
% large interword gaps.
\newcolumntype{L}[1]{>{\raggedright\arraybackslash}p{#1}}
\newcolumntype{Y}{>{\raggedright\arraybackslash}X}
\newcommand{\ragcol}[1]{>{\raggedright\arraybackslash}p{#1}}

% ==========================================================================
% UNITED STATES CODE REPRODUCTION COMMANDS (existing-law text in the
% comparative print). Carried unchanged from the template and draft styles so
% the reproduced section files render identically.
% ==========================================================================
\newcommand{\usctitlehead}[2]{%
  \begin{center}
  {\Large\bfseries #1}\\[0.25em]
  {\Large\bfseries #2}
  \end{center}}

\newcommand{\uscchapterhead}[2]{%
  \par\addvspace{1.4\baselineskip}%
  \needspace{4\baselineskip}%
  \phantomsection\addcontentsline{toc}{section}{#1 #2}%
  \begin{center}{\large\bfseries #1\\[0.15em]#2}\end{center}%
  \par\addvspace{0.5\baselineskip}}

\newcommand{\uscsubchapterhead}[1]{%
  \par\addvspace{1.1\baselineskip}%
  \needspace{3\baselineskip}%
  \phantomsection\addcontentsline{toc}{subsection}{#1}%
  \begin{center}{\bfseries #1}\end{center}%
  \par\addvspace{0.35\baselineskip}}

\newcommand{\uscparthead}[1]{%
  \par\addvspace{0.8\baselineskip}%
  \needspace{3\baselineskip}%
  \phantomsection\addcontentsline{toc}{subsection}{#1}%
  \begin{center}{\bfseries\scshape #1}\end{center}%
  \par\addvspace{0.3\baselineskip}}

% Section catchline: "§ 360e-4. Predetermined change control plans ...". A short
% running mark is set so PDF structure is preserved, but the running header uses
% the fixed fields above rather than this mark, so a long catchline can never
% overflow the header.
\newcommand{\uscsection}[2]{%
  \par\addvspace{1.15\baselineskip}%
  \needspace{4\baselineskip}%
  \phantomsection
  \addcontentsline{toc}{subsubsection}{#1 #2}%
  {\setlength{\parindent}{0pt}\bfseries\large #1\hskip 0.45em #2\par}%
  \nopagebreak\par\addvspace{0.35\baselineskip}}

% Statutory provision with a hanging indent at depth #1 (0 = flush body).
\newcommand{\uscprov}[2]{%
  \par
  \begingroup
  \ifnum#1>0
    \setlength{\leftskip}{\dimexpr#1\uscunit\relax}%
    \setlength{\parindent}{-\uscunit}%
  \else
    \setlength{\leftskip}{0pt}%
    \setlength{\parindent}{1.0em}%
  \fi
  #2\par
  \endgroup}

% Quoted statutory or amendment text, indented and set off (used for the new
% section 360e-5 rendered as quoted matter to be inserted, and for clerical
% amendment items).
\newcommand{\uscquote}[2]{%
  \par
  \begingroup
  \setlength{\leftskip}{\dimexpr#1\uscunit + \uscunit\relax}%
  \setlength{\rightskip}{0.5\uscunit}%
  \setlength{\parindent}{0.8em}%
  \small #2\par
  \endgroup}

% Source credit: parenthetical Public Law lineage at the left margin.
\newcommand{\uscsource}[1]{%
  \par\addvspace{0.25\baselineskip}%
  {\setlength{\parindent}{0pt}\small #1\par}%
  \addvspace{0.2\baselineskip}}

% Cross-heading: centered bold (Editorial Notes; Statutory Notes ...).
\newcommand{\usccrosshead}[1]{%
  \par\addvspace{0.7\baselineskip}%
  \needspace{2.5\baselineskip}%
  \begin{center}{\bfseries #1}\end{center}%
  \par\addvspace{0.2\baselineskip}}

% Note heading: centered small caps (Amendments; Effective Date; ...).
\newcommand{\uscnotehead}[1]{%
  \par\addvspace{0.45\baselineskip}%
  \needspace{2\baselineskip}%
  \begin{center}{\scshape #1}\end{center}%
  \par\addvspace{0.1\baselineskip}}

% Note paragraph: flush body text within a note.
\newcommand{\uscnotepar}[1]{%
  \par{\setlength{\parindent}{1.0em}#1\par}}

% ==========================================================================
% CONGRESSIONAL AMENDMENT APPARATUS.
% ==========================================================================

% Bill caption: Congress and session at the left, bill number at the right.
% \billcaption{119TH CONGRESS}{2d Session}{H. R. 9510}
\newcommand{\billcaption}[3]{%
  \begin{center}
  \makebox[\textwidth][s]{\bfseries #1\hfill #3}\\[0.15em]
  {\itshape #2}
  \end{center}%
  \vspace{0.2em}\noindent\rule{\textwidth}{0.8pt}\par}

% Long title: "To amend ... and for other purposes." centered, narrow measure.
\newcommand{\billlongtitle}[1]{%
  \par\addvspace{0.4\baselineskip}%
  \begin{center}\begin{minipage}{0.86\textwidth}\centering #1\end{minipage}\end{center}%
  \par\addvspace{0.3\baselineskip}}

% Referral block: chamber, date, and the "introduced the following bill" line.
\newcommand{\billintro}[3]{%
  \par\addvspace{0.3\baselineskip}%
  \begin{center}{\scshape #1}\\[0.2em]{\itshape #2}\end{center}%
  \par{\setlength{\parindent}{1.0em}#3\par}%
  \par\addvspace{0.3\baselineskip}}

% "A BILL" head, centered, with rules above and below.
\newcommand{\billhead}{%
  \par\addvspace{0.5\baselineskip}%
  \noindent\rule{\textwidth}{0.8pt}\par
  \begin{center}\vspace{0.1cm}{\LARGE\bfseries A BILL}\vspace{-0.2cm}\end{center}%
  \noindent\rule{\textwidth}{0.8pt}\par
  \addvspace{0.3\baselineskip}}

% Enacting clause, per congressional convention.
\newcommand{\enactingclause}{%
  \par\addvspace{0.3\baselineskip}%
  {\itshape Be it enacted by the Senate and House of Representatives of the
  United States of America in Congress assembled,}\par
  \addvspace{0.4\baselineskip}}

% Cover-page provenance note: a set-off, small, clearly non-operative note for
% the caption page. It is visually distinct from operative bill text so it is
% never mistaken for statutory language.
\newcommand{\billcovernote}[1]{%
  \par\addvspace{0.4\baselineskip}%
  \begingroup
  \footnotesize\itshape\RaggedRight
  \setlength{\parindent}{0pt}%
  \noindent\rule{\linewidth}{0.4pt}\par\vspace{2pt}%
  #1\par
  \vspace{-3pt}\noindent\rule{\linewidth}{0.4pt}\par
  \endgroup
  \addvspace{0.4\baselineskip}}

% Bill-section catchline, run in to the first line of text.
% \billsec{SECTION 1.}{SHORT TITLE; TABLE OF CONTENTS.}
\newcommand{\billsec}[2]{%
  \par\addvspace{0.9\baselineskip}%
  \needspace{4\baselineskip}%
  \phantomsection
  \addcontentsline{toc}{section}{#1 #2}%
  {\setlength{\parindent}{0pt}\bfseries #1\hskip 0.4em #2\par}%
  \nopagebreak\par\addvspace{0.2\baselineskip}}

% Comparative-print convention markers. Matter proposed to be deleted is shown
% as [strike: ...]; matter proposed to be inserted is shown as [insert: ...] in
% italics; unchanged law is plain text. No strikethrough or underline is used.
\newcommand{\cprstrike}[1]{[strike: #1]}
\newcommand{\cprinsert}[1]{[insert: \textit{#1}]}

\endinput
