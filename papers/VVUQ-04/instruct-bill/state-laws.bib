@misc{ca-ab3030,
  author    = {{California State Legislature}},
  title     = {Assembly Bill 3030 (2024): Health Care Services, Artificial Intelligence},
  year      = {2024},
  publisher = {California Legislative Information},
  url       = {https://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202320240AB3030},
  note      = {Chapter 848, Statutes of 2024; effective Jan. 1, 2025. Generative AI patient communications must carry an AI disclaimer and human-contact instructions. \url{https://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202320240AB3030}.}
}

@misc{ca-sb1120,
  author    = {{California State Legislature}},
  title     = {Senate Bill 1120 (2024): Physicians Make Decisions Act, Health Care Coverage Utilization Review},
  year      = {2024},
  publisher = {California Legislative Information},
  url       = {https://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202320240SB1120},
  note      = {Chapter 879, Statutes of 2024; effective Jan. 1, 2025. AI in utilization review may not replace a physician's medical-necessity determination and is subject to audit. The flagship human-in-the-loop model. \url{https://leginfo.legislature.ca.gov/faces/billNavClient.xhtml?bill_id=202320240SB1120}.}
}

@misc{ca-ab489,
  author    = {{California State Legislature}},
  title     = {Assembly Bill 489 (2025): Health Care Professions, Deceptive Terms, Artificial Intelligence},
  year      = {2025},
  publisher = {California Legislative Information},
  url       = {https://leginfo.legislature.ca.gov/faces/billTextClient.xhtml?bill_id=202520260AB489},
  note      = {Chapter 615, Statutes of 2025; operative Jan. 1, 2026. AI may not use terms implying it holds a health-care license. Models anti-impersonation. \url{https://leginfo.legislature.ca.gov/faces/billTextClient.xhtml?bill_id=202520260AB489}.}
}

@misc{ca-mbc-genai,
  author    = {{Medical Board of California}},
  title     = {Generative AI Notification Guidance (Implementing AB 3030)},
  year      = {2025},
  publisher = {Medical Board of California},
  url       = {https://www.mbc.ca.gov/Resources/Medical-Resources/GenAI-Notification.aspx},
  note      = {Board guidance operationalizing the AB 3030 disclaimer and human-contact requirement. \url{https://www.mbc.ca.gov/Resources/Medical-Resources/GenAI-Notification.aspx}.}
}

@misc{co-sb24-205,
  author    = {{Colorado General Assembly}},
  title     = {Senate Bill 24-205: Colorado Artificial Intelligence Act, Consumer Protections for AI},
  year      = {2024},
  publisher = {Colorado General Assembly},
  url       = {https://leg.colorado.gov/bills/sb24-205},
  note      = {Enacted May 2024; effective June 30, 2026 (delayed by SB 25B-004); enforcement paused by a federal court Apr. 27, 2026. Duty of care for high-risk AI in consequential decisions including health care. \url{https://leg.colorado.gov/bills/sb24-205}.}
}

@misc{co-sb25b-004,
  author    = {{Colorado General Assembly}},
  title     = {Senate Bill 25B-004 (2025 Special Session): Colorado AI Act Implementation Delay},
  year      = {2025},
  publisher = {Colorado General Assembly},
  url       = {https://leg.colorado.gov/bills/sb25b-004},
  note      = {Signed Aug. 28, 2025; postpones the Colorado AI Act effective date to June 30, 2026. \url{https://leg.colorado.gov/bills/sb25b-004}.}
}

@misc{co-sb21-169,
  author    = {{Colorado General Assembly}},
  title     = {Senate Bill 21-169 (2021): Restrict Insurers' Use of External Consumer Data and Algorithms},
  year      = {2021},
  publisher = {Colorado General Assembly},
  url       = {https://leg.colorado.gov/bills/sb21-169},
  note      = {Enacted July 6, 2021; implementing Regulation 10-1-1 effective Oct. 15, 2025 for health insurers. Requires testing algorithms for unfair discrimination with documented governance, the closest model to automated VVUQ plus bias auditing. \url{https://leg.colorado.gov/bills/sb21-169}.}
}

@misc{ut-sb149,
  author    = {{Utah State Legislature}},
  title     = {Senate Bill 149 (2024): Artificial Intelligence Policy Act},
  year      = {2024},
  publisher = {Utah State Legislature},
  url       = {https://le.utah.gov/~2024/bills/static/SB0149.html},
  note      = {Effective May 1, 2024. Regulated occupations including health professions must conspicuously disclose generative AI before an interaction. \url{https://le.utah.gov/~2024/bills/static/SB0149.html}.}
}

@misc{ut-hb452,
  author    = {{Utah State Legislature}},
  title     = {House Bill 452 (2025): Artificial Intelligence Amendments, Mental Health Chatbots},
  year      = {2025},
  publisher = {Utah State Legislature},
  url       = {https://le.utah.gov/~2025/bills/static/HB0452.html},
  note      = {Effective May 7, 2025. Provides an affirmative defense conditioned on documenting training data, models, and ongoing accuracy, safety, and fairness efforts. A direct cousin of a VVUQ-evidence safe harbor. \url{https://le.utah.gov/~2025/bills/static/HB0452.html}.}
}

@misc{tx-hb149,
  author    = {{Texas Legislature}},
  title     = {House Bill 149 (2025): Texas Responsible Artificial Intelligence Governance Act (TRAIGA)},
  year      = {2025},
  publisher = {Texas Legislature Online},
  url       = {https://capitol.texas.gov/tlodocs/89R/billtext/pdf/HB00149I.pdf},
  note      = {Signed June 22, 2025; effective Jan. 1, 2026. Comprehensive AI governance with prohibited uses, a sandbox, and an AI advisory council. The sandbox model for piloting a Physical AI oncology regime. \url{https://capitol.texas.gov/tlodocs/89R/billtext/pdf/HB00149I.pdf}.}
}

@misc{tx-sb1822,
  author    = {{Texas Legislature}},
  title     = {Senate Bill 1822 (2025): Artificial Intelligence-Based Algorithms in Utilization Review (Did Not Pass)},
  year      = {2025},
  publisher = {Texas Legislature Online},
  url       = {https://capitol.texas.gov/BillLookup/History.aspx?LegSess=89R&Bill=SB1822},
  note      = {Passed the Senate but left pending in House committee; did not pass. Would have required an annual attestation that algorithms minimize bias. A bias-attestation template, flagged as not enacted. \url{https://capitol.texas.gov/BillLookup/History.aspx?LegSess=89R&Bill=SB1822}.}
}

@misc{il-hb1806,
  author    = {{Illinois General Assembly}},
  title     = {House Bill 1806 (2025): Wellness and Oversight for Psychological Resources (WOPR) Act},
  year      = {2025},
  publisher = {Illinois General Assembly},
  url       = {https://www.ilga.gov/documents/legislation/104/HB/10400HB1806.htm},
  note      = {Public Act 104-0054; effective Aug. 4, 2025. AI may not make independent therapeutic decisions or generate treatment plans without review by a licensed professional. Among the strongest no-autonomous-clinical-action statutes. \url{https://www.ilga.gov/documents/legislation/104/HB/10400HB1806.htm}.}
}

@misc{md-hb820,
  author    = {{Maryland General Assembly}},
  title     = {House Bill 820 (2025): Health Insurance, Utilization Review, Use of Artificial Intelligence},
  year      = {2025},
  publisher = {Maryland General Assembly},
  url       = {https://mgaleg.maryland.gov/mgawebsite/Legislation/Details/HB0820?ys=2025RS},
  note      = {Chapter 747; effective Oct. 1, 2025. AI in utilization review must use individual clinical information, may not deny care autonomously, and is open to audit. \url{https://mgaleg.maryland.gov/mgawebsite/Legislation/Details/HB0820?ys=2025RS}.}
}

@misc{ne-lb77,
  author    = {{Nebraska Legislature}},
  title     = {Legislative Bill 77 (2025): Ensuring Transparency in Prior Authorization Act},
  year      = {2025},
  publisher = {Nebraska Legislature},
  url       = {https://nebraskalegislature.gov/FloorDocs/109/PDF/Slip/LB77.pdf},
  note      = {Approved June 4, 2025. An AI algorithm may not be the sole basis to deny or delay care, and AI use must be disclosed. \url{https://nebraskalegislature.gov/FloorDocs/109/PDF/Slip/LB77.pdf}.}
}

@misc{nv-ab406,
  author    = {{Nevada Legislature}},
  title     = {Assembly Bill 406 (2025): Artificial Intelligence in Mental and Behavioral Health},
  year      = {2025},
  publisher = {Nevada Legislature},
  url       = {https://www.leg.state.nv.us/Session/83rd2025/Bills/AB/AB406_EN.pdf},
  note      = {Chapter 283; effective July 1, 2025. Bars AI from constituting the practice of professional mental health and allows AI only with independent human review. \url{https://www.leg.state.nv.us/Session/83rd2025/Bills/AB/AB406_EN.pdf}.}
}

@misc{ny-a9149,
  author    = {{New York State Assembly}},
  title     = {Assembly Bill A9149 (2023-2024): Artificial Intelligence in Utilization Review},
  year      = {2024},
  publisher = {New York State Assembly},
  url       = {https://www.nysenate.gov/legislation/bills/2023/A9149},
  note      = {Pending; carried with companion bills. Would require submission of utilization-review algorithms to the Department of Financial Services for bias certification. \url{https://www.nysenate.gov/legislation/bills/2023/A9149}.}
}

@misc{ny-dfs-cl7,
  author    = {{New York State Department of Financial Services}},
  title     = {Insurance Circular Letter No. 7 (2024): AI Systems and External Consumer Data in Underwriting and Pricing},
  year      = {2024},
  publisher = {New York State Department of Financial Services},
  url       = {https://www.dfs.ny.gov/industry-guidance/circular-letters/cl2024-07},
  note      = {In effect July 11, 2024. Insurers using AI must test for unfair discrimination and maintain governance and documentation. A bias-testing analogue. \url{https://www.dfs.ny.gov/industry-guidance/circular-letters/cl2024-07}.}
}

@misc{fsmb-ai,
