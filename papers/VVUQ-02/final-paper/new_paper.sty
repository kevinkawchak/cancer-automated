% ============================================================
% new_paper.sty
% Style file for:
%   10 Mobile Pancreatic Cancer Unitree H2 Surgical Humanoids:
%   VVUQ Processing Priority over Code Generation
%
% Palatino serif, single column, dark black accents. Carried unchanged from the
% VVUQ-02 draft-paper style so the full manuscript keeps the same text colour
% formatting as the draft and the Template_04 family. Do not change the black
% accent, the Palatino body, or the abstract box; the look must be preserved.
% ============================================================
\NeedsTeXFormat{LaTeX2e}
\ProcessOptions\relax

\renewcommand{\rmdefault}{ppl}
\renewcommand{\sfdefault}{phv}

\usepackage[verbose=true,letterpaper]{geometry}
\AtBeginDocument{
  \newgeometry{textheight=9in,textwidth=6.4in,top=1in,headheight=14pt,headsep=20pt,footskip=30pt}
}

% \definecolor{black}{HTML}{0B2545}

\widowpenalty=10000
\clubpenalty=10000
\flushbottom
\sloppy

\newcommand{\headeright}{}
\newcommand{\shorttitle}{\@title}

\usepackage{fancyhdr}
\fancyhf{}
\pagestyle{fancy}
\renewcommand{\headrulewidth}{0pt}
\fancyheadoffset{0pt}
\rhead{\small\color{black}\thepage}
\lhead{\footnotesize\itshape\shorttitle}

\def\keywordname{{\color{black}\bfseries Keywords}}%
\def\keywords#1{\par\addvspace\medskipamount{\rightskip=0pt plus1cm
\def\and{\ifhmode\unskip\nobreak\fi\ |\
}\noindent\keywordname\enspace\ignorespaces#1\par}}

\renewcommand{\normalsize}{\@setfontsize\normalsize\@xipt{13.6}}
\normalsize

\providecommand{\section}{}
\renewcommand{\section}{\@startsection{section}{1}{\z@}
  {-2.2ex \@plus -0.5ex \@minus -0.2ex}{1.5ex \@plus 0.3ex \@minus 0.2ex}
  {\large\bfseries\sffamily\color{black}\raggedright}}
\providecommand{\subsection}{}
\renewcommand{\subsection}{\@startsection{subsection}{2}{\z@}
  {-1.6ex \@plus -0.4ex \@minus -0.2ex}{0.6ex \@plus 0.2ex}
  {\normalsize\bfseries\sffamily\color{black}\raggedright}}

\setlength{\parindent}{\z@}
\setlength{\parskip}{5.5\p@}

\providecommand{\maketitle}{}
\renewcommand{\maketitle}{\par\begingroup
  \thispagestyle{empty}\@maketitle\endgroup
  \let\maketitle\relax}

\providecommand{\@maketitle}{}
\renewcommand{\@maketitle}{\vbox{\hsize\textwidth \linewidth\hsize
  \vskip 0.1in
  {\color{black}\rule{\textwidth}{4pt}}\vskip 0.15in
  \raggedright {\Huge\bfseries\sffamily\color{black}\@title\par}\vskip 0.3in
  {\large\@author}\vskip 0.1in
  {\small\@date}\vskip 0.2in
  {\color{black}\rule{\textwidth}{1pt}}\vskip 0.15in}}

\renewenvironment{abstract}
  {\par\noindent\colorbox{black!8}{\parbox{\dimexpr\textwidth-2\fboxsep}{
    {\bfseries\color{black} Abstract.}\quad}}\par\vskip 0.3em\begin{quote}}
  {\end{quote}}

\endinput
